 {
        "family": "fargate-quotes-api",
        "networkMode": "awsvpc",
        "executionRoleArn": "arn:aws:iam::<aws-id>:role/ecsTaskExecutionRole", 
        "containerDefinitions": [
            {
                "name": "fargate-app",
                "image": "<aws-id>.dkr.ecr.eu-central-1.amazonaws.com/zeni-repo:latest",
                "portMappings": [
                    {
                        "containerPort": 5000,
                        "hostPort": 5000,
                        "protocol": "tcp"
                    }
                ],
                "essential": true,
                "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                  "awslogs-group": "/ecs/quotes-api",
                  "awslogs-region": "eu-central-1",
                  "awslogs-stream-prefix": "ecs"
                  }
                }
            }
        ],
        "requiresCompatibilities": [
            "FARGATE"
        ],
        "cpu": "256",
        "memory": "512"
}